FROM eclipse-temurin:21-jdk-jammy

RUN apt-get update && apt-get install -y \
    python3 python3-pip stress net-tools iputils-ping netcat-traditional telnet \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY jade-agents/lib/jade.jar /app/lib/

COPY monitoring/requirements.txt /app/
RUN pip3 install -r requirements.txt

RUN mkdir -p /app/classes

CMD sh -c 'echo "Waiting for JADE main container at $JADE_HOST:1099..." && \
sleep 10 && \
echo "Attempting to connect..." && \
until timeout 2 bash -c "echo > /dev/tcp/$JADE_HOST/1099" 2>/dev/null; do \
  echo "Waiting for main container..."; \
  sleep 3; \
done && \
echo "JADE main container is ready, compiling agents..." && \
javac -cp lib/jade.jar -d classes src/agents/LocalAgent.java src/agents/CentralServerAgent.java src/agents/MobileAuditAgent.java 2>&1 && \
echo "Starting local agent container for $NODE_ID..." && \
java -cp lib/jade.jar:classes \
-Djava.net.preferIPv4Stack=true \
jade.Boot \
-container \
-host $JADE_HOST \
-port 1099 \
-container-name Container-$NODE_ID \
local-agent-$NODE_ID:agents.LocalAgent\($NODE_ID\)'